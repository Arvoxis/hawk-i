backend/detections.jsonl
detections.jsonl
captures/

# Auto-generated reports
reports/
*.pdf

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Microsoft Office temp files
~$*.docx
~$*.xlsx
~$*.pptx

