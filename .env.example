# ── Network / hosts ───────────────────────────────────────────
# GCS_HOST     : IP of the laptop/PC running the FastAPI backend
# JETSON_HOST  : IP of the Jetson on the same network
# RECEIVER_PORT: standalone receiver.py port (must differ from GCS_PORT)
GCS_HOST=<laptop_ip>
GCS_PORT=8000
JETSON_HOST=<jetson_ip>
RECEIVER_PORT=8001

# ── Jetson hardware ────────────────────────────────────────────
MAVLINK_SERIAL=/dev/ttyTHS1

# ── Ollama / LLM ──────────────────────────────────────────────
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hawki_db
DB_USER=hawki_user
DB_PASSWORD=<your_password>

# ── GCS display (optional) ────────────────────────────────────
# GCS_HEADLESS=1
# GCS_SAVE_DIR=captures
# GCS_AUTO_SAVE=0
# GCS_AUTO_SAVE_CONF=0.70
# GCS_LOG_FILE=detections.jsonl

# ── Camera intrinsics (SAM2 GSD formula) ──────────────────────
# Adjust these for your actual drone camera hardware.
# Defaults match a typical Raspberry Pi HQ cam (IMX477).
CAMERA_FOCAL_MM=3.67
CAMERA_SENSOR_WIDTH_MM=6.287
CAMERA_IMAGE_WIDTH_PX=1280
